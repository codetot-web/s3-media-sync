{
  "name": "codetot/s3-media-sync",
  "description": "WordPress plugin to sync media library to any S3-compatible storage",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "codetot",
      "homepage": "https://github.com/codetot"
    }
  ],
  "require": {
    "php": ">=7.4",
    "aws/aws-sdk-php": "^3.0 <3.288"
  },
  "autoload": {
    "psr-4": {
      "S3MediaSync\\": "includes/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "audit": {
      "ignore": ["PKSA-4t1p-xpk2-nsss", "PKSA-dxyf-6n16-t87m", "PKSA-n3s6-289w-qtqb", "PKSA-stsw-jsf7-f6vs"]
    }
  }
}
